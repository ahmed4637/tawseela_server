NODE_ENV=production
PORT=4000

# MongoDB. DB_URI is supported for compatibility with the existing server environment.
MONGO_URI=mongodb://127.0.0.1:27017/tawseela
# DB_URI=mongodb://127.0.0.1:27017/tawseela
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=30d

PUBLIC_API_URL=https://tawseela.store/api
BASE_URL=https://tawseela.store

# Workers
DISABLE_WORKERS=false

# Firebase push notifications. Use ONE of the two supported methods.
# Method 1: full JSON in one env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Method 2: split fields.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Initial admin seeder
ADMIN_NAME=Tawseela Admin
ADMIN_EMAIL=admin@tawseela.com
ADMIN_PHONE=01000000000
ADMIN_PASSWORD=change_this_password
